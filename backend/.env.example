PORT=4000
# Local: mongodb://127.0.0.1:27017/little-stories
# Atlas: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/little-stories?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/little-stories
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
FRONTEND_URL=https://story-app-dusky.vercel.app

# Stripe (optional — omit or leave blank to disable checkout until configured)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
